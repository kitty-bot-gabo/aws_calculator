# aws_calculator
APP_PORT=8099

# LLM: disabled, ollama, openai, deepseek
LLM_PROVIDER=ollama
LLM_ALLOW_EXTERNAL=false
LLM_TIMEOUT_SECONDS=120

# Ollama local
LLM_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=llama3.1:8b
OLLAMA_MODELS=llama3.1:8b,qwen3.5:9b

# OpenAI - secretos solo backend .env
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MODELS=gpt-4.1-mini,gpt-4.1,gpt-4o-mini

# DeepSeek - secretos solo backend .env
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_MODELS=deepseek-v4-flash,deepseek-v4-pro,deepseek-chat,deepseek-reasoner

# AWS Calculator public endpoints used by calculator.aws / sample MCP. No AWS credentials.
AWS_MANIFEST_URL=
AWS_SAVE_URL=
